{
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:8080",
        "Protocols": "Http1"
      },
      "Grpc": {
        "Url": "http://0.0.0.0:8081",
        "Protocols": "Http2"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Key": "THIS_IS_YOUR_SUPER_SECRET_KEY_32+_CHARS",
    "Issuer": "AuthService",
    "Audience": "ApiGateway",
    "ExpiresMinutes": 15,
    "RefreshTokenExpiresDays": 7
  },
  "ConnectionStrings": {
    "Database": "Server=localhost; Port=5432; Database=CatalogDb; User Id=postgres; Password=postgres; Include Error Detail=true"
  }
}
